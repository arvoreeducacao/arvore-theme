  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#7C98A1",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#8DE5DA"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language.boolean"],
      "settings": {
        "foreground": "#FCA78D"
      }
    },
    {
      "scope": ["constant.language", "constant.character", "constant.other"],
      "settings": {
        "foreground": "#FCA78D"
      }
    },
    {
      "scope": ["variable", "variable.other", "variable.parameter"],
      "settings": {
        "foreground": "#E6FAF7"
      }
    },
    {
      "scope": ["variable.other.constant", "variable.other.enummember"],
      "settings": {
        "foreground": "#FDC3B1"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#B29CE7"
      }
    },
    {
      "scope": ["keyword.operator", "keyword.operator.assignment"],
      "settings": {
        "foreground": "#B7C7CB"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#8DAEF6"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#66DCCE"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#66DCCE"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#B29CE7",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["entity.other.inherited-class", "entity.name.type.interface"],
      "settings": {
        "foreground": "#B3E577"
      }
    },
    {
      "scope": ["punctuation", "meta.brace"],
      "settings": {
        "foreground": "#B7C7CB"
      }
    },
    {
      "scope": ["support.type.property-name"],
      "settings": {
        "foreground": "#E6FAF7"
      }
    },
    {
      "scope": ["entity.name.tag.css", "support.type.property-name.css"],
      "settings": {
        "foreground": "#B7C7CB"
      }
    },
    {
      "scope": [
        "support.constant.property-value.css",
        "support.constant.color"
      ],
      "settings": {
        "foreground": "#8DE5DA"
      }
    },
    {
      "scope": [
        "meta.selector.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#66DCCE"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#FC98AB"
      }
    },
    {
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#8DE5DA"
      }
    },
    {
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": {
        "foreground": "#FCA78D"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#E6FAF7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#8DE5DA"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#4EC685"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#FA5371"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#6394F3"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#66DCCE"
      }
    },
    {
      "scope": ["meta.embedded", "source.groovy.embedded"],
      "settings": {
        "foreground": "#E6FAF7"
      }
    },
    {
      "scope": ["entity.name.section"],
      "settings": {
        "foreground": "#E6FAF7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["support.module", "entity.name.module"],
      "settings": {
        "foreground": "#66DCCE"
      }
    },
    {
      "scope": ["variable.language.this", "variable.language.self"],
      "settings": {
        "foreground": "#B29CE7",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["entity.name.function.decorator"],
      "settings": {
        "foreground": "#FCA78D"
      }
    },
    {
      "scope": ["meta.type.annotation", "support.type.primitive"],
      "settings": {
        "foreground": "#66DCCE"
      }
    },
    {
      "scope": ["variable.other.property"],
      "settings": {
        "foreground": "#ADECE5"
      }
    }
  ],
  "semanticTokenColors": {
    "type": "#66DCCE",
    "type.declaration": "#66DCCE",
    "class": "#66DCCE",
    "class.declaration": { "foreground": "#66DCCE", "bold": true },
    "interface": "#B3E577",
    "interface.declaration": { "foreground": "#B3E577", "bold": true },
    "enum": "#66DCCE",
    "enumMember": "#FDC3B1",
    "function": "#8DAEF6",
    "function.declaration": { "foreground": "#8DAEF6", "bold": true },
    "method": "#8DAEF6",
    "method.declaration": { "foreground": "#8DAEF6", "bold": true },
    "parameter": "#E6FAF7",
    "variable": "#E6FAF7",
    "variable.readonly": "#FDC3B1",
    "property": "#ADECE5",
    "property.declaration": "#ADECE5",
    "property.readonly": "#FDC3B1",
    "namespace": "#66DCCE",
    "decorator": "#FCA78D",
    "keyword": "#B29CE7",
    "comment": { "foreground": "#7C98A1", "italic": true },
    "string": "#8DE5DA",
    "number": "#FCA78D",
    "regexp": "#FC98AB",
    "operator": "#B7C7CB",
    "typeParameter": "#B3E577"
  }
}
