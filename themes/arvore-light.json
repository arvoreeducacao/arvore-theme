  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#B7C7CB",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#309385"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language.boolean"],
      "settings": {
        "foreground": "#FB673A"
      }
    },
    {
      "scope": ["constant.language", "constant.character", "constant.other"],
      "settings": {
        "foreground": "#FB673A"
      }
    },
    {
      "scope": ["variable", "variable.other", "variable.parameter"],
      "settings": {
        "foreground": "#053B4B"
      }
    },
    {
      "scope": ["variable.other.constant", "variable.other.enummember"],
      "settings": {
        "foreground": "#C63B0B"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#8764D8"
      }
    },
    {
      "scope": ["keyword.operator", "keyword.operator.assignment"],
      "settings": {
        "foreground": "#406A76"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#4F81F1"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#39AF9F"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#40CAB6"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#8764D8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["entity.other.inherited-class", "entity.name.type.interface"],
      "settings": {
        "foreground": "#7FC923"
      }
    },
    {
      "scope": ["punctuation", "meta.brace"],
      "settings": {
        "foreground": "#7C98A1"
      }
    },
    {
      "scope": ["support.type.property-name"],
      "settings": {
        "foreground": "#053B4B"
      }
    },
    {
      "scope": ["entity.name.tag.css", "support.type.property-name.css"],
      "settings": {
        "foreground": "#406A76"
      }
    },
    {
      "scope": [
        "support.constant.property-value.css",
        "support.constant.color"
      ],
      "settings": {
        "foreground": "#309385"
      }
    },
    {
      "scope": [
        "meta.selector.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#40CAB6"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#FA5371"
      }
    },
    {
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#66DCCE"
      }
    },
    {
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": {
        "foreground": "#FB673A"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#053B4B",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#309385"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#3DA169"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#FA163E"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#4F81F1"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#40CAB6"
      }
    },
    {
      "scope": ["meta.embedded", "source.groovy.embedded"],
      "settings": {
        "foreground": "#053B4B"
      }
    },
    {
      "scope": ["entity.name.section"],
      "settings": {
        "foreground": "#053B4B",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["support.module", "entity.name.module"],
      "settings": {
        "foreground": "#39AF9F"
      }
    },
    {
      "scope": ["variable.language.this", "variable.language.self"],
      "settings": {
        "foreground": "#8764D8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["entity.name.function.decorator"],
      "settings": {
        "foreground": "#FB673A"
      }
    },
    {
      "scope": ["meta.type.annotation", "support.type.primitive"],
      "settings": {
        "foreground": "#39AF9F"
      }
    },
    {
      "scope": ["variable.other.property"],
      "settings": {
        "foreground": "#406A76"
      }
    }
  ],
  "semanticTokenColors": {
    "type": "#39AF9F",
    "type.declaration": "#39AF9F",
    "class": "#39AF9F",
    "class.declaration": { "foreground": "#39AF9F", "bold": true },
    "interface": "#7FC923",
    "interface.declaration": { "foreground": "#7FC923", "bold": true },
    "enum": "#39AF9F",
    "enumMember": "#C63B0B",
    "function": "#4F81F1",
    "function.declaration": { "foreground": "#4F81F1", "bold": true },
    "method": "#4F81F1",
    "method.declaration": { "foreground": "#4F81F1", "bold": true },
    "parameter": "#053B4B",
    "variable": "#053B4B",
    "variable.readonly": "#C63B0B",
    "property": "#406A76",
    "property.declaration": "#406A76",
    "property.readonly": "#C63B0B",
    "namespace": "#39AF9F",
    "decorator": "#FB673A",
    "keyword": "#8764D8",
    "comment": { "foreground": "#B7C7CB", "italic": true },
    "string": "#309385",
    "number": "#FB673A",
    "regexp": "#FA5371",
    "operator": "#406A76",
    "typeParameter": "#7FC923"
  }
}
